# API URL para conectar con el backend
# En un dispositivo físico, NO uses localhost (ese es el propio dispositivo)
# Usa la IP de tu máquina en la red local

# Windows - obtener IP con: ipconfig
# Ejemplo:
EXPO_PUBLIC_API_URL=http://192.168.1.100:3003

# Si usas emulador de Android en tu PC:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3003
